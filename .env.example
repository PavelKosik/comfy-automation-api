# Copy to .env and adjust. All values are optional; defaults shown below.

# ComfyUI server location (local or remote)
COMFYUI_HOST=127.0.0.1
COMFYUI_PORT=8188
COMFYUI_SCHEME=http

# Where decoded images are written (created if missing)
OUTPUT_DIR=./outputs

# Client id reported to ComfyUI
CLIENT_ID=comfy-automation-api

# Per-job wait timeout (seconds) and history poll interval (seconds)
JOB_TIMEOUT=900
POLL_INTERVAL=2.0
